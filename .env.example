# ============================================================
# AIGündem — ortam değişkenleri şablonu
# ============================================================
# Gerçek değerleri .env.local'a yazın (bu dosya commit edilir,
# .env.local GitHub'a gönderilmez).
# Kopyalama:  cp .env.example .env.local

# Supabase — proje URL'i ve API anahtarları
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase — doğrudan PostgreSQL erişimi (migration script'leri için)
SUPABASE_DB_PASSWORD=your-db-password
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project.supabase.co:5432/postgres

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=AIGündem

# İletişim formu captcha (HMAC-SHA256 için 32+ karakter)
# Üret:  openssl rand -hex 32
CAPTCHA_SECRET=

# Resend — bülten onay mailleri için
# Test: onboarding@resend.dev (sadece hesap sahibine gönderir)
# Prod: doğrulanmış alan adı (örn. bulten@aigundem.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=AIGündem <onboarding@resend.dev>

# Anthropic (opsiyonel — özet üretimi için)
ANTHROPIC_API_KEY=
